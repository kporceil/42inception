# Configuration MariaDB minimale
# Ce fichier est lu par mysqld au démarrage

[mysqld]
# Répertoire des données (doit correspondre au volume)
datadir         = /var/lib/mysql

# Port d'écoute standard MySQL/MariaDB
port            = 3306

# Désactive skip-networking (actif par défaut sur Alpine)
skip-networking = 0
bind-address    = 0.0.0.0

# Socket Unix (utilisé pour les connexions locales, ex: mysqladmin)
socket          = /run/mysqld/mysqld.sock

# Encodage par défaut : utf8mb4 pour support unicode complet
character-set-server    = utf8mb4
collation-server        = utf8mb4_general_ci

[client]
# Le client utilise aussi le socket Unix par défaut
socket = /run/mysqld/mysqld.sock
